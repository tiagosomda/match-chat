# Copy to .env and fill in. The .env file is gitignored.

# --- API-Football (https://dashboard.api-football.com) ---
API_FOOTBALL_KEY=your_api_sports_key_here

# --- Firebase Admin (service account JSON downloaded from the Firebase console:
#     Project settings -> Service accounts -> Generate new private key) ---
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# --- Tournament identifiers (defaults target FIFA World Cup 2026) ---
LEAGUE_ID=1
SEASON=2026
TOURNAMENT_ID=world-cup-2026
TOURNAMENT_NAME=FIFA World Cup 2026

# --- Polling behaviour ---
# How often to poll while at least one match is live (seconds).
POLL_INTERVAL_SECONDS=300
# The budget guard widens the interval toward this when the daily quota runs low.
MAX_POLL_INTERVAL_SECONDS=900
# Wake this many seconds before a kickoff to start the live loop.
PREKICKOFF_WAKE_SECONDS=120
# Stay under the free plan's 100/day. The guard slows polling as we approach it.
DAILY_REQUEST_BUDGET=90

# --- Local state ---
CACHE_FILE=./.poller-cache.json
